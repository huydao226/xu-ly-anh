          <mxGeometry x="1220" y="650" width="190" height="100" as="geometry" />
        </mxCell>

        <mxCell id="note1" value="Model does not use raw image directly.&#xa;Each frame is converted into a 19-dimensional feature vector first." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#94A3B8;dashed=1;fontSize=12;" vertex="1" parent="1">
