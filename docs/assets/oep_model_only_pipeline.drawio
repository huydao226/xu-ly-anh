        <mxCell id="s1" value="Webcam Image / Video Stream" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2FE;strokeColor=#0369A1;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="140" width="170" height="70" as="geometry" />
        </mxCell>
        <mxCell id="s2" value="Take Consecutive Frames" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#15803D;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="260" y="140" width="170" height="70" as="geometry" />
        </mxCell>
        <mxCell id="s3" value="Resize Frame&#xa;to fixed width" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#B45309;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="480" y="140" width="160" height="70" as="geometry" />
        </mxCell>
        <mxCell id="s4" value="Convert to&#xa;Grayscale" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F1F5F9;strokeColor=#475569;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="690" y="140" width="150" height="70" as="geometry" />
        </mxCell>
