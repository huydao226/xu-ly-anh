<mxfile host="app.diagrams.net" modified="2026-04-03T00:00:00.000Z" agent="Codex" version="24.7.17">
  <diagram id="training-pipeline" name="Training Pipeline">
    <mxGraphModel dx="1800" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="t_title" value="OEP Training Pipeline" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=22;fontStyle=1;fontColor=#1F2937;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="340" height="30" as="geometry" />
        </mxCell>

        <mxCell id="t1" value="OEP webcam segments CSV&#xa;+ raw videos" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2FE;strokeColor=#0369A1;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="120" width="190" height="80" as="geometry" />
        </mxCell>
        <mxCell id="t2" value="build_oep_temporal_dataset_v3.py" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#15803D;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="280" y="120" width="220" height="80" as="geometry" />
        </mxCell>
        <mxCell id="t3" value="Sample frames&#xa;from labeled time segments" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#B45309;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="550" y="120" width="190" height="80" as="geometry" />
        </mxCell>
        <mxCell id="t4" value="Resize + Grayscale&#xa;+ extract 19 features / frame" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE7F3;strokeColor=#BE185D;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="790" y="120" width="220" height="80" as="geometry" />
        </mxCell>
        <mxCell id="t5" value="Create temporal sequence&#xa;(default 16 frames/sample)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#6D28D9;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="1060" y="120" width="210" height="80" as="geometry" />
        </mxCell>
        <mxCell id="t6" value="Remap labels to 3 classes&#xa;normal / suspicious_action / device" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#1D4ED8;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="1320" y="120" width="240" height="80" as="geometry" />
        </mxCell>

        <mxCell id="t7" value="Save processed dataset&#xa;oep_webcam_temporal_v3.jsonl" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D1FAE5;strokeColor=#047857;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="620" y="270" width="230" height="80" as="geometry" />
        </mxCell>
        <mxCell id="t8" value="train_temporal_model.py" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2FE;strokeColor=#0369A1;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="620" y="400" width="230" height="70" as="geometry" />
        </mxCell>

        <mxCell id="t9" value="Split by subject&#xa;train / val / test" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#15803D;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="120" y="540" width="180" height="80" as="geometry" />
        </mxCell>
        <mxCell id="t10" value="Compute feature mean/std&#xa;+ class weights" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#B45309;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="360" y="540" width="210" height="80" as="geometry" />
        </mxCell>
        <mxCell id="t11" value="TemporalSequenceDataset&#xa;+ DataLoader" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE7F3;strokeColor=#BE185D;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="640" y="540" width="210" height="80" as="geometry" />
        </mxCell>
        <mxCell id="t12" value="TemporalClassifier&#xa;(deployed model: LSTM)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BFDBFE;strokeColor=#1D4ED8;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="920" y="540" width="210" height="80" as="geometry" />
        </mxCell>
        <mxCell id="t13" value="Forward pass&#xa;sequence -&gt; logits (3 classes)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DDD6FE;strokeColor=#6D28D9;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="1200" y="540" width="210" height="80" as="geometry" />
        </mxCell>

        <mxCell id="t14" value="Weighted CrossEntropyLoss&#xa;(compare logits with true label)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#B91C1C;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="520" y="700" width="250" height="90" as="geometry" />
        </mxCell>
        <mxCell id="t15" value="Backward + gradient clip&#xa;+ Adam optimizer.step()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE4E6;strokeColor=#BE123C;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="840" y="700" width="240" height="90" as="geometry" />
        </mxCell>
        <mxCell id="t16" value="Validation each epoch&#xa;track val loss / val accuracy" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2FE;strokeColor=#0369A1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="1150" y="700" width="230" height="90" as="geometry" />
        </mxCell>
        <mxCell id="t17" value="Save best_model.pt&#xa;when validation improves" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#15803D;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1450" y="700" width="220" height="90" as="geometry" />
        </mxCell>

        <mxCell id="t18" value="Load best model&#xa;evaluate on val/test" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#B45309;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="520" y="860" width="220" height="80" as="geometry" />
        </mxCell>
        <mxCell id="t19" value="Tune non-normal threshold" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE7F3;strokeColor=#BE185D;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="810" y="860" width="200" height="80" as="geometry" />
        </mxCell>
        <mxCell id="t20" value="Export artifacts&#xa;best_model.pt&#xa;metrics.json&#xa;label_map.json" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D1FAE5;strokeColor=#047857;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1090" y="850" width="240" height="100" as="geometry" />
        </mxCell>

        <mxCell id="tn1" value="Dataset building stage" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#94A3B8;dashed=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="160" height="30" as="geometry" />
        </mxCell>
        <mxCell id="tn2" value="Training stage" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#94A3B8;dashed=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="500" width="120" height="30" as="geometry" />
        </mxCell>

