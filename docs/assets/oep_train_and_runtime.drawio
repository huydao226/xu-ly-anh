  <diagram id="runtime-pipeline" name="Runtime Frame Processing">
    <mxGraphModel dx="1800" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="r_title" value="OEP Runtime Frame Processing" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=22;fontStyle=1;fontColor=#1F2937;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="420" height="30" as="geometry" />
        </mxCell>

        <mxCell id="r1" value="Incoming webcam frame&#xa;(base64 image payload)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2FE;strokeColor=#0369A1;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="120" width="220" height="80" as="geometry" />
        </mxCell>
        <mxCell id="r2" value="Decode image" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#15803D;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="320" y="120" width="160" height="80" as="geometry" />
        </mxCell>
        <mxCell id="r3" value="Resize frame" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#B45309;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="540" y="120" width="150" height="80" as="geometry" />
        </mxCell>
        <mxCell id="r4" value="Convert to grayscale" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F1F5F9;strokeColor=#475569;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="750" y="120" width="170" height="80" as="geometry" />
        </mxCell>
        <mxCell id="r5" value="Extract 19 features&#xa;using current frame&#xa;+ previous_gray" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE7F3;strokeColor=#BE185D;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="980" y="110" width="220" height="100" as="geometry" />
        </mxCell>
        <mxCell id="r6" value="Feature vector (19D)&#xa;+ new gray frame" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#6D28D9;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="1260" y="120" width="190" height="80" as="geometry" />
        </mxCell>

        <mxCell id="r7" value="Update session state&#xa;previous_gray = current gray" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#1D4ED8;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="180" y="300" width="220" height="80" as="geometry" />
        </mxCell>
        <mxCell id="r8" value="Append vector to&#xa;feature_buffer (maxlen=16)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D1FAE5;strokeColor=#047857;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="470" y="300" width="220" height="80" as="geometry" />
        </mxCell>
        <mxCell id="r9" value="Buffer size &lt; 8 ?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#B91C1C;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="780" y="305" width="150" height="70" as="geometry" />
        </mxCell>
        <mxCell id="r10" value="Not enough frames yet&#xa;keep collecting sequence" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE4E6;strokeColor=#BE123C;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="1010" y="300" width="210" height="80" as="geometry" />
        </mxCell>

        <mxCell id="r11" value="Take current feature buffer&#xa;(up to 16 frames)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2FE;strokeColor=#0369A1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="330" y="500" width="220" height="90" as="geometry" />
        </mxCell>
        <mxCell id="r12" value="Normalize sequence&#xa;with feature_mean / feature_std" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#15803D;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="620" y="500" width="240" height="90" as="geometry" />
        </mxCell>
        <mxCell id="r13" value="Create tensor + length tensor" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#B45309;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="930" y="500" width="210" height="90" as="geometry" />
        </mxCell>
        <mxCell id="r14" value="TemporalClassifier&#xa;(LSTM deployed)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BFDBFE;strokeColor=#1D4ED8;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1210" y="500" width="190" height="90" as="geometry" />
        </mxCell>

        <mxCell id="r15" value="Logits for 3 classes" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DDD6FE;strokeColor=#6D28D9;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="260" y="700" width="180" height="80" as="geometry" />
        </mxCell>
        <mxCell id="r16" value="Softmax" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE7F3;strokeColor=#BE185D;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="500" y="700" width="160" height="80" as="geometry" />
        </mxCell>
        <mxCell id="r17" value="Probabilities&#xa;device / normal / suspicious_action" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D1FAE5;strokeColor=#047857;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="720" y="690" width="230" height="100" as="geometry" />
        </mxCell>
        <mxCell id="r18" value="Choose top class" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2FE;strokeColor=#0369A1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="1010" y="700" width="170" height="80" as="geometry" />
        </mxCell>
        <mxCell id="r19" value="Apply non-normal threshold" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#B91C1C;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1240" y="700" width="210" height="80" as="geometry" />
        </mxCell>
        <mxCell id="r20" value="Model prediction&#xa;label + confidence + scores" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#15803D;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1510" y="690" width="220" height="100" as="geometry" />
        </mxCell>

        <mxCell id="rn1" value="Only the model path is shown here.&#xa;YOLO and runtime overrides are intentionally omitted." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#94A3B8;dashed=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="860" width="320" height="70" as="geometry" />
        </mxCell>

        <mxCell id="re1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;jettySize=auto;html=1;strokeColor=#475569;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1" source="r1" target="r2"><mxGeometry relative="1" as="geometry" /></mxCell>
