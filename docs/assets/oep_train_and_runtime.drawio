        <mxCell id="re9" value="Yes" style="edgeStyle=orthogonalEdgeStyle;rounded=0;jettySize=auto;html=1;strokeColor=#334155;strokeWidth=2;endArrow=block;endFill=1;fontSize=12;" edge="1" parent="1" source="r9" target="r10"><mxGeometry relative="1" as="geometry" /></mxCell>
